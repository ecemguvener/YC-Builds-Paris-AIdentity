NODE_ENV=development
API_PORT=4001
PUBLIC_APP_URL=http://localhost:4888
PUBLIC_API_URL=http://localhost:4001
MONGODB_URI=mongodb://127.0.0.1:27017/aidentity
# When NODE_ENV=production, the API uses a MongoDB database name ending in -prod.
# For example, the value above becomes mongodb://127.0.0.1:27017/aidentity-prod.
SESSION_COOKIE_NAME=aidentity_session
SESSION_SECRET=replace-with-a-long-random-secret
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ELEVENLABS_VOICE_ID=kPzsL2i3teMYv0FxEYQ6
OPENAI_API_KEY=
OPENAI_DASHBOARD_CHAT_MODEL=gpt-5.4-2026-03-05
# Model used by the payment tool to parse natural-language purchases
# ("buy me still water from amazon"). Falls back to a built-in heuristic
# parser when OPENAI_API_KEY is unset.
OPENAI_PAYMENTS_MODEL=gpt-4o-mini

# --- Email capability add-on ------------------------------------------------
# Real email sending/receiving for an agent identity. When RESEND_API_KEY is
# blank the capability runs in MOCK mode (logs the message, returns a synthetic
# id) so the full request -> send -> reply flow is demoable without a domain.
RESEND_API_KEY=
# The verified sending domain. Agent addresses are minted as
# <name>-<rand>@<EMAIL_FROM_DOMAIN> (e.g. ava-ab12@aidentity.space).
EMAIL_FROM_DOMAIN=aidentity.space
# Resend webhook signing secret for inbound replies. Paste the `whsec_...`
# secret from the Resend webhook settings to verify the Svix signature. (A
# plain non-whsec value instead requires a matching X-Webhook-Secret header —
# handy for local testing.)
EMAIL_WEBHOOK_SECRET=
# Model used to draft emails from plain text and summarize inbound replies.
# Falls back to a heuristic when OPENAI_API_KEY is unset.
OPENAI_EMAIL_MODEL=gpt-4o-mini
