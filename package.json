{
  "name": "aidentity-web",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "seed:demo": "npm --workspace @aidentity/api run seed:demo",
    "pm2:start-prod-api": "pm2 startOrReload ecosystem.config.cjs --only prod-aidentity-api --update-env && pm2 save",
    "pm2:list": "pm2 list",
    "build": "npm --workspaces --if-present run build",
    "deploy:aidentity-web": "bash scripts/deploy-aidentity-web.sh",
    "deploy-aidentity-web": "npm run deploy:aidentity-web",
    "test": "npm --workspaces --if-present run test",
    "lint": "npm --workspaces --if-present run lint"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
